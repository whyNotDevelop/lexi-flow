# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True

# PostgreSQL
POSTGRES_DB=lexiflow
POSTGRES_USER=lexiflow_user
POSTGRES_PASSWORD=lexiflow_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Optional: Database URL for Django
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}